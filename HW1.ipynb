   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "ts = [0,1,2]\n",
    "\n",
    "x = np.linspace(-5,5,100)\n",
    "\n",
    "def f(x,t):\n",
    "    return 1 / np.cosh(x-t)\n",
    "for t in ts:\n",
    "    y = f(x,t)\n",
    "    plt.plot(x,y, label=f\"$t = {t}$\")\n",
    "plt.xticks(np.arange(-5,5.1,1))\n",
    "plt.legend()\n",
    "plt.grid()"
   ],
